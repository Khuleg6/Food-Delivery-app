// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Хэрэглэгчийн эрх
enum UserRole {
  USER
  ADMIN
}

// Захиалгын төлөв
enum FoodOrderStatus {
  PENDING
  CANCELED
  DELIVERED
}

// 1. Хэрэглэгч
model User {
  id          String      @id @default(uuid())
  email       String      @unique
  password    String
  phoneNumber String
  address     String
  role        UserRole    @default(USER)
  ttl         DateTime?
  isVerified  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orders      FoodOrder[]
}

// 2. Хоолны ангилал
model FoodCategory {
  id           String   @id @default(uuid())
  categoryName String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  foods        Food[]
}

// 3. Хоол
model Food {
  id          String          @id @default(uuid())
  foodName    String
  price       Float
  image       String
  ingredients String
  categoryId  String
  category    FoodCategory    @relation(fields: [categoryId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  orderItems  FoodOrderItem[]
}

// 4. Захиалга
model FoodOrder {
  id             String          @id @default(uuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id])
  totalPrice     Float
  status         FoodOrderStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  foodOrderItems FoodOrderItem[]
}

// 5. Захиалсан хоолны жагсаалт (Relational DB-д тусдаа хүснэгт болно)
model FoodOrderItem {
  id       String    @id @default(uuid())
  orderId  String
  order    FoodOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodId   String
  food     Food      @relation(fields: [foodId], references: [id])
  quantity Int
}
